# AI provider (set at least one)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=job-pipeline

# Job sources
SERPAPI_KEY=
APIFY_TOKEN=
APIFY_LINKEDIN_ACTOR=harvestapi/linkedin-jobs-scraper

# Google Sheets / Service Account
GOOGLE_SHEET_ID=
GOOGLE_API_KEY=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_TAB=Jobs

# Supabase migration/runtime
# Use the publishable key here; do not expose a service role key in the frontend.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Backend Supabase runtime (server-side only)
# Required for pipeline + backend API writes/updates.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Notifications
GMAIL_USER=
GMAIL_PASS=
# Comma-separated recipients supported
ALERT_RECIPIENTS=dineshsevenni@gmail.com
# Send alerts only for jobs at/above this group: LOW | GOOD | HIGH | ALL
ALERT_MIN_GROUP=GOOD
WEBSITE_URL=https://dinesh2841.github.io/job-pipeline/

# Pipeline options
# Global fetch locations (cities) and allowed state filters
JOB_LOCATION=Chennai,Bangalore,Hyderabad,Vijayawada,Visakhapatnam,Coimbatore,Mysore
ALLOWED_STATES=Tamil Nadu,Andhra Pradesh,Telangana,Karnataka
SEARCH_LOCATION=India

# Software pipeline
SW_JOB_KEYWORDS=software engineer,frontend developer,backend developer,full stack developer
SW_ROLE_SKILLS=node.js,react,javascript,python,java,express,mongodb,rest api

# Embedded / IoT pipeline
EM_JOB_KEYWORDS=embedded engineer,embedded systems engineer,firmware engineer,iot engineer,embedded developer
EM_ROLE_SKILLS=c,c++,embedded,rtos,microcontroller,esp32,arduino,embedded c,device driver,iot

# Core ECE / VLSI pipeline
HW_JOB_KEYWORDS=vlsi engineer,fpga engineer,asic engineer,design verification engineer,physical design engineer
HW_ROLE_SKILLS=vlsi,verilog,vhdl,systemverilog,asic,fpga,physical design,analog design,digital design
DAYS_TO_KEEP=14
RUN_CRON_LOCALLY=false

# Frontend (Vite)
VITE_BACKEND_URL=http://localhost:4000
