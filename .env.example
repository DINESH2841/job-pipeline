# AI provider (set at least one)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=job-pipeline

# Job sources
SERPAPI_KEY=
APIFY_TOKEN=
APIFY_LINKEDIN_ACTOR=harvestapi/linkedin-jobs-scraper

# Google Sheets / Service Account
GOOGLE_SHEET_ID=
GOOGLE_API_KEY=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_TAB=Jobs

# Notifications
GMAIL_USER=
GMAIL_PASS=
# Comma-separated recipients supported
ALERT_RECIPIENTS=dineshsevenni@gmail.com
WEBSITE_URL=https://dinesh2841.github.io/job-pipeline/

# Pipeline options
JOB_KEYWORDS=software engineer,frontend developer,full stack developer
JOB_LOCATION=India
DAYS_TO_KEEP=14
RUN_CRON_LOCALLY=false

# Frontend (Vite)
VITE_GOOGLE_SHEET_ID=
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_SHEET_RANGE=Jobs!A:G
VITE_BACKEND_URL=http://localhost:4000
