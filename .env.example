# AI provider (set at least one)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=job-pipeline

# Job sources
SERPAPI_KEY=
APIFY_TOKEN=
APIFY_LINKEDIN_ACTOR=harvestapi/linkedin-jobs-scraper

# Google Sheets / Service Account
GOOGLE_SHEET_ID=
GOOGLE_API_KEY=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEET_TAB=Jobs

# Notifications
GMAIL_USER=
GMAIL_PASS=
# Comma-separated recipients supported
ALERT_RECIPIENTS=dineshsevenni@gmail.com
# Send alerts only for jobs at/above this group: LOW | GOOD | HIGH | ALL
ALERT_MIN_GROUP=GOOD
WEBSITE_URL=https://dinesh2841.github.io/job-pipeline/

# Pipeline options
# Comma-separated job role keywords to search for (Software + ECE combined)
JOB_KEYWORDS=software engineer,frontend developer,full stack developer,backend developer,ece engineer,electronics engineer,graduate engineer trainee,get trainee,electronics trainee,hardware engineer,pcb design engineer,embedded engineer,embedded systems engineer,firmware engineer,microcontroller engineer,rtos engineer,vlsi engineer,vlsi design engineer,physical design engineer,analog design engineer,digital design engineer,design verification engineer,fpga engineer,asic engineer,signal processing engineer,communication engineer,rf engineer,antenna engineer,embedded developer,embedded c developer,embedded software engineer,iot engineer,iot developer,edge computing engineer,esp32 developer,arduino developer,raspberry pi developer,firmware developer,device driver engineer,robotics engineer,automation engineer,control systems engineer,linux engineer,systems engineer,testing engineer,validation engineer
# Skill groups separated by | (pipe), each skill group separated by comma
# Format: skill1,skill2,skill3|skill4,skill5,skill6
# Each group represents a job category (software, ECE, etc)
ROLE_SKILLS=node.js,react,javascript,backend,frontend,python,java,express,mongodb,rest api|c,c++,embedded,signal processing,vlsi,circuit design,ece,fpga,asic,rtos,microcontroller,embedded systems,hardware,pcb,iot,arduino,esp32,embedded c,device driver,robotics,control systems,rf,antenna,communication,physical design,analog design,digital design,verilog,vhdl,systemverilog
JOB_LOCATION=India
DAYS_TO_KEEP=14
RUN_CRON_LOCALLY=false

# Frontend (Vite)
VITE_GOOGLE_SHEET_ID=
VITE_GOOGLE_API_KEY=
VITE_GOOGLE_SHEET_RANGE=Jobs!A:G
VITE_BACKEND_URL=http://localhost:4000
